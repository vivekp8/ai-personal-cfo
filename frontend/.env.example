# Frontend build-time configuration for the AI Personal CFO.
# Copy to `.env` (or `.env.production`) and set before running `npm run build`.

# Base URL the frontend uses to reach the backend API.
# - Dev: leave unset — Vite proxies /api -> http://localhost:8000.
# - Production: set to the backend's public URL, e.g.
#   VITE_API_BASE=https://api.your-domain.com
# If unset in production, requests go to "/api" and a reverse proxy must
# forward /api to the backend.
VITE_API_BASE=
