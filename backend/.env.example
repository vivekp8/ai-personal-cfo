# Copy this file to `.env` and fill in your real values. Never commit `.env`.

# ---- LLM providers ----
# The router tries providers in this priority order and skips any without a key:
#   1. Gemini  2. Groq  3. GitHub Models  4. OpenRouter  5. Ollama (local)
GEMINI_API_KEY=
GROQ_API_KEY=
GITHUB_TOKEN=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# auto = try providers in priority order; or force one: gemini|groq|github|openrouter|ollama
DEFAULT_PROVIDER=auto

# ---- Optional model overrides ----
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
GITHUB_MODEL=gpt-4o-mini
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OLLAMA_MODEL=llama3.2

# ---- Cache ----
LLM_CACHE_TTL=900
# Leave REDIS_URL empty to use the in-memory cache; set it to enable Redis.
REDIS_URL=

# ---- Voice assistant (Phase: Voice) ----
# STT provider priority (comma-separated, first available wins, then failover):
#   groq_whisper (needs GROQ_API_KEY) | whisper_local (offline, needs openai-whisper)
STT_PROVIDER=groq_whisper,whisper_local
# TTS provider priority: gtts (online) | edge_tts (needs `pip install edge-tts`)
TTS_PROVIDER=gtts,edge_tts

# Feature toggles
ENABLE_STREAMING=true
ENABLE_MEMORY=true
ENABLE_RAG=true
ENABLE_OFFLINE_MODE=true
VOICE_AUTO_RETRY=true

# STT tuning
WHISPER_MODEL=small
WHISPER_LANG=en
GROQ_STT_MODEL=whisper-large-v3-turbo
# Retry another STT provider below this confidence (0..1)
VOICE_STT_MIN_CONFIDENCE=0.75

# TTS tuning
VOICE_TTS_LANG=en
EDGE_TTS_VOICE=en-US-AriaNeural

# ---- Deployment ----
# Comma-separated list of allowed browser origins in production, e.g.
# ALLOWED_ORIGINS=https://cfo.example.com,https://www.cfo.example.com
# Leave as "*" for local development (credentials are disabled with "*").
ALLOWED_ORIGINS=*
